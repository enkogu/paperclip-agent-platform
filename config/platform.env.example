# Canonical platform environment input
#
# This is the only environment template in the repository. Copy it to a
# private path outside the checkout, chmod it 0600, fill the operator-owned
# values, and pass it with --operator-env or MTE_OPERATOR_ENV.
#
# Bootstrap imports recognized non-empty values fill-only into the single live
# runtime source of truth:
#
#   /root/.config/mte-secrets/platform.env
#
# Safe defaults, pinned images, ports, generated service passwords/tokens and
# provisioned resource IDs are materialized into that same canonical file.
# Services never read this operator-side input file, and an existing non-empty
# canonical value is never overwritten by ordinary init/deploy operations.
# Validate a populated private copy without printing values:
#
#   ./platform --operator-env /secure/path/platform.env config check

# Required deployment identity. Documentation-only TEST-NET addresses and the
# example.com domain below are not deployment defaults.
MTE_SSH_TARGET=root@203.0.113.10
MTE_OPERATOR_SSH_CIDRS=2001:db8::/32,203.0.113.0/24
MTE_EXCLUDED_HOST_1=192.0.2.10
MTE_EXCLUDED_HOST_2=198.51.100.10
PLATFORM_BASE_DOMAIN=agents.example.com

# Required Cloudflare token bootstrap inputs. The global key remains local;
# bootstrap derives a scoped API token and stores only governed runtime values
# in the canonical server-side platform.env.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_EMAIL=
CLOUDFLARE_GLOBAL_API_KEY=

# Required external credentials/configuration for the shipped end-to-end
# profile. They are imported into the canonical file but never emitted in
# logs, evidence or generated public configuration.
GITHUB_TOKEN=
MINIMAX_API_KEY=
MINIMAX_BASE_URL=
MINIMAX_MODEL=
NOTION_TOKEN=
NOTION_ROOT_PAGE_ID=

# Optional native Hermes Telegram entrypoint. Empty values keep it disabled.
HERMES_TELEGRAM_BOT_TOKEN=
HERMES_TELEGRAM_ALLOWED_USERS=
