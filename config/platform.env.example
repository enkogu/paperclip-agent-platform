# Canonical operator input: the repository's only environment template.
# Copy it to config/platform.env, chmod it 0600, and complete every required
# value. Bootstrap fill-only imports non-empty values into the root-owned
# runtime materialization at /root/.config/mte-secrets/platform.env; services
# read only that file and ordinary installation never overwrites its populated
# generated values. Validate without printing values: ./install.sh preflight
# Required deployment identity; TEST-NET and example.com are documentation only.
MTE_SSH_TARGET=root@203.0.113.10
MTE_OPERATOR_SSH_CIDRS=2001:db8::/32,203.0.113.0/24
MTE_EXCLUDED_HOST_1=192.0.2.10
MTE_EXCLUDED_HOST_2=198.51.100.10
PLATFORM_BASE_DOMAIN=agents.example.com

# Required non-secret host admission thresholds: KiB except load (milli-units/CPU).
MTE_RESOURCE_PREFLIGHT_MIN_MEM_TOTAL_KIB=20971520
MTE_RESOURCE_PREFLIGHT_MIN_MEM_AVAILABLE_KIB=6291456
MTE_RESOURCE_PREFLIGHT_MAX_SWAP_USED_KIB=1048576
MTE_RESOURCE_PREFLIGHT_MAX_LOAD_PER_CPU_MILLI=1500
MTE_RESOURCE_PREFLIGHT_MIN_ROOT_FREE_KIB=31457280
MTE_RESOURCE_PREFLIGHT_MIN_DOCKER_FREE_KIB=31457280

# Required immutable Paperclip runtime: signed-release digest, source URL, revision.
# Source URL is compared byte-for-byte to the OCI label: use canonical HTTPS
# (lowercase host, repository path; no credentials, port, query, fragment,
# trailing slash, or dot segments). Validation never rewrites this evidence.
MTE_PAPERCLIP_IMAGE=
MTE_PAPERCLIP_FORK_SOURCE_URL=
MTE_PAPERCLIP_FORK_REVISION=

# Required immutable Daytona harness: CI digest, source URL, and 40-char revision.
# The deploy path never builds it and rejects tags or missing evidence.
MTE_DAYTONA_SANDBOX_IMAGE=
MTE_DAYTONA_SANDBOX_IMAGE_SOURCE_URL=
MTE_DAYTONA_SANDBOX_IMAGE_REVISION=

# Required Cloudflare bootstrap inputs. The global key stays local; only governed
# derived values enter the root-owned runtime materialization.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_EMAIL=
CLOUDFLARE_GLOBAL_API_KEY=

# Required shipped end-to-end profile inputs; never emitted in logs, evidence, or public config.
GITHUB_TOKEN=
E2E_GITHUB_OWNER=example-org
E2E_GITHUB_REPOSITORY=agent-canary
E2E_GITHUB_BASE_BRANCH=main
MINIMAX_API_KEY=
MINIMAX_BASE_URL=
MINIMAX_MODEL=
NOTION_TOKEN=
NOTION_ROOT_PAGE_ID=

# Reviewed Daytona harnesses use profile-scoped 9router keys and MiniMax, not
# native Codex/Claude subscriptions, login, or OAuth. Keep false for public
# input; true deliberately enables operator-provided Codex and Claude clients.
MTE_ENABLE_OPERATOR_PROVIDED_PROPRIETARY_HARNESSES=false

# High-risk exception: true permits unattended owner bootstrap only for an
# explicit non-human Paperclip invite request; normal installs require approval.
MTE_ALLOW_UNATTENDED_PAPERCLIP_OWNER_BOOTSTRAP=false

# Optional Context7 auth: empty uses anonymous fallback; non-empty is fill-only
# and reaches agents only through Paperclip-managed secret references.
CONTEXT7_API_KEY=

# Optional native Hermes Telegram entrypoint. Empty values keep it disabled.
HERMES_TELEGRAM_BOT_TOKEN=
HERMES_TELEGRAM_ALLOWED_USERS=
