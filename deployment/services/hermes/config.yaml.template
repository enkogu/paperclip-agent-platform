model:
  default: @@HERMES_LLM_MODEL@@
  provider: @@HERMES_LLM_PROVIDER@@
  base_url: @@HERMES_LLM_BASE_URL@@
  api_mode: @@HERMES_LLM_API_MODE@@

# Hermes deliberately does not forward OPENAI_API_KEY to arbitrary custom
# hosts (including loopback). Give the private 9router endpoint an explicit
# named-provider identity so upstream Hermes resolves the credential from the
# service environment without embedding it in this file.
custom_providers:
  - name: mte9router
    base_url: @@HERMES_LLM_BASE_URL@@
    key_env: OPENAI_API_KEY
    api_mode: @@HERMES_LLM_API_MODE@@

terminal:
  backend: @@HERMES_TERMINAL_BACKEND@@
  cwd: @@HERMES_TERMINAL_CWD@@
  timeout: @@HERMES_TERMINAL_TIMEOUT@@
  lifetime_seconds: @@HERMES_TERMINAL_LIFETIME_SECONDS@@
  home_mode: @@HERMES_TERMINAL_HOME_MODE@@

# The private deployment may grant the dedicated Hermes account broad sudo
# access. Commands still follow Hermes' native approval policy; no custom API
# bridge or command wrapper sits between Hermes and its terminal tool.
command_allowlist: []

approvals:
  mode: @@HERMES_APPROVALS_MODE@@
  timeout: @@HERMES_APPROVALS_TIMEOUT@@
  cron_mode: @@HERMES_APPROVALS_CRON_MODE@@
  mcp_reload_confirm: @@HERMES_APPROVALS_MCP_RELOAD_CONFIRM@@
  destructive_slash_confirm: @@HERMES_APPROVALS_DESTRUCTIVE_SLASH_CONFIRM@@

streaming:
  enabled: @@HERMES_GATEWAY_STREAMING_ENABLED@@
  transport: @@HERMES_GATEWAY_STREAMING_TRANSPORT@@

telegram:
  require_mention: @@HERMES_TELEGRAM_REQUIRE_MENTION@@
  exclusive_bot_mentions: @@HERMES_TELEGRAM_EXCLUSIVE_BOT_MENTIONS@@
  guest_mode: @@HERMES_TELEGRAM_GUEST_MODE@@

display:
  tool_progress: @@HERMES_DISPLAY_TOOL_PROGRESS@@
  platforms:
    telegram:
      notifications: @@HERMES_TELEGRAM_NOTIFICATIONS@@

@@HERMES_MATTERMOST_CONFIG@@

@@HERMES_CONTEXT7_MCP@@
